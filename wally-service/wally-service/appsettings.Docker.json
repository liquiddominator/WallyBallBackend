{
  "ConnectionStrings": {
    "SqlServer": "Server=sqlserver,1433;Database=WallyBallDb;User Id=sa;Password=Your_password123;TrustServerCertificate=True;Encrypt=False"
  },
  "Jwt": {
    "Issuer": "PersonasService",
    "Audience": "WallyBallClients",
    "SigningKey": "development-signing-key-change-before-production-32",
    "ExpirationMinutes": 120,
    "RefreshTokenExpirationDays": 7,
    "MaxFailedLoginAttempts": 5,
    "LockoutMinutes": 15
  },
  "PersonasService": {
    "BaseUrl": "http://host.docker.internal:5097"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
